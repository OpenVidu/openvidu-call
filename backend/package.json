{
	"name": "openvidu-call-server",
	"version": "3.0.0-beta3",
	"description": "OpenVidu Call Server",
	"author": "OpenVidu",
	"license": "Apache-2.0",
	"homepage": "https://github.com/OpenVidu/openvidu-call#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OpenVidu/openvidu-call.git"
	},
	"bugs": {
		"url": "https://github.com/OpenVidu/openvidu-call/issues"
	},
	"keywords": [
		"openvidu",
		"webrtc",
		"openvidu-call"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"start": "node dist/src/server.js",
		"dev:start": "cross-env USE_HTTPS=false SERVER_CORS_ORIGIN=* nodemon -I --exec node --experimental-specifier-resolution=node --loader ts-node/esm ./src/server.ts",
		"lint": "eslint src --fix",
		"format": "prettier --ignore-path .gitignore --write '**/*.{ts,js,json,md}'",
		"package": "npm run build && npm pack",
		"lib:sync-call-pro": "npm run package && cp openvidu-call-server-*.tgz ../../openvidu-call-pro/backend",
		"test:embedded-auth-api": "node --experimental-vm-modules node_modules/.bin/jest --forceExit tests/api/embedded/token.test.ts",
		"generate:embedded-clients": "node scripts/generate-embedded-client.js all",
		"generate:embedded-ts-client": "node scripts/generate-embedded-client.js ts",
		"generate:embedded-java-client": "node scripts/generate-embedded-client.js java"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.673.0",
		"chalk": "5.4.1",
		"cors": "2.8.5",
		"dotenv": "16.4.7",
		"express": "4.21.2",
		"express-basic-auth": "1.2.1",
		"express-openapi-validator": "^5.4.2",
		"express-rate-limit": "^7.5.0",
		"inversify": "^6.2.1",
		"ioredis": "^5.4.2",
		"livekit-server-sdk": "2.6.2",
		"reflect-metadata": "^0.2.2",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"winston": "3.14.2",
		"yamljs": "^0.3.0"
	},
	"devDependencies": {
		"@openapitools/openapi-generator-cli": "^2.16.3",
		"@types/cookie-parser": "1.4.7",
		"@types/cors": "2.8.17",
		"@types/express": "4.17.21",
		"@types/jest": "^29.5.14",
		"@types/node": "^20.12.14",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.6",
		"@types/validator": "^13.12.2",
		"@types/yamljs": "^0.2.34",
		"@typescript-eslint/eslint-plugin": "6.7.5",
		"@typescript-eslint/parser": "6.7.5",
		"cross-env": "7.0.3",
		"eslint": "8.50.0",
		"eslint-config-prettier": "9.0.0",
		"jest": "^29.7.0",
		"nodemon": "3.1.9",
		"openapi-zod-client": "1.18.2",
		"prettier": "3.3.3",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-jest-resolver": "^2.0.1",
		"ts-node": "10.9.2",
		"typescript": "5.4.5"
	}
}
